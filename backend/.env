# ── LLM Provider ────────────────────────────────────────────────
# Use one or both. The agent will prefer ANTHROPIC if both are set.
ANTHROPIC_API_KEY=sk-ant-your-key-here
OPENAI_API_KEY=sk-your-openai-key-here
LLM_PROVIDER=anthropic          # anthropic | openai

# ── Platform Credentials ────────────────────────────────────────
# Twitter / X
TWITTER_USERNAME=your_twitter_handle
TWITTER_PASSWORD=your_twitter_password

# LinkedIn
LINKEDIN_EMAIL=you@email.com
LINKEDIN_PASSWORD=your_linkedin_password

# Reddit
REDDIT_USERNAME=your_reddit_user
REDDIT_PASSWORD=your_reddit_password

# WhatsApp (via WhatsApp Web — browser session)
# No credentials needed. The agent opens WhatsApp Web; you scan QR once.
WHATSAPP_SESSION_DIR=./sessions/whatsapp

# ── Server ──────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
CORS_ORIGIN=http://localhost:5173

# ── Browser Use ─────────────────────────────────────────────────
BROWSER_HEADLESS=false          # false = you can watch the browser work
BROWSER_SLOW_MO=500             # ms delay between actions (human-like)
