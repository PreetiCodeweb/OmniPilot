###############################################################################
# OmniPilot Configuration
###############################################################################

APP_NAME=OmniPilot
APP_ENV=development
DEBUG=true

###############################################################################
# Server
###############################################################################

HOST=0.0.0.0
PORT=8000
CORS_ORIGIN=http://localhost:5173

###############################################################################
# AI Provider
###############################################################################

LLM_PROVIDER=openai

# OpenAI
OPENAI_API_KEY=YOUR_OPENAI_API_KEY
OPENAI_MODEL=gpt-5.5

# Anthropic
ANTHROPIC_API_KEY=YOUR_ANTHROPIC_API_KEY
ANTHROPIC_MODEL=claude-opus-4-1

# Google
GOOGLE_API_KEY=YOUR_GOOGLE_API_KEY
GOOGLE_MODEL=gemini-2.5-pro

# Groq (Optional)
GROQ_API_KEY=YOUR_GROQ_API_KEY

# OpenRouter (Optional)
OPENROUTER_API_KEY=YOUR_OPENROUTER_API_KEY

###############################################################################
# Browser
###############################################################################

BROWSER_HEADLESS=false
BROWSER_SLOW_MO=300

BROWSER_WIDTH=1440
BROWSER_HEIGHT=900

BROWSER_TIMEOUT=60000

###############################################################################
# Browser Profiles
###############################################################################

CHROME_USER_DATA=./sessions/chrome

TWITTER_SESSION=./sessions/twitter
LINKEDIN_SESSION=./sessions/linkedin
REDDIT_SESSION=./sessions/reddit
WHATSAPP_SESSION=./sessions/whatsapp

###############################################################################
# Platform Accounts (Optional)
# Leave blank if using browser sessions.
###############################################################################

TWITTER_USERNAME= 
TWITTER_PASSWORD=

LINKEDIN_EMAIL=
LINKEDIN_PASSWORD=

REDDIT_USERNAME=
REDDIT_PASSWORD=

###############################################################################
# Memory
###############################################################################

ENABLE_MEMORY=true

MEMORY_PROVIDER=sqlite
MEMORY_DB=./data/memory.db

###############################################################################
# Vector Database
###############################################################################

VECTOR_DB=chroma
CHROMA_PATH=./data/chroma

###############################################################################
# Embeddings
###############################################################################

EMBEDDING_PROVIDER=openai
EMBEDDING_MODEL=text-embedding-3-large

###############################################################################
# Retrieval (RAG)
###############################################################################

ENABLE_RAG=true

DOCUMENTS_PATH=./knowledge

###############################################################################
# Vision
###############################################################################

ENABLE_VISION=true
SCREENSHOT_QUALITY=90

###############################################################################
# Voice
###############################################################################

ENABLE_VOICE=false

STT_PROVIDER=openai
TTS_PROVIDER=openai

###############################################################################
# Code Execution
###############################################################################

ENABLE_CODE_EXECUTION=true

###############################################################################
# Web Search
###############################################################################

ENABLE_WEB_SEARCH=true

###############################################################################
# File System
###############################################################################

ENABLE_FILE_SYSTEM=true

###############################################################################
# Multi-Agent
###############################################################################

ENABLE_MULTI_AGENT=true

###############################################################################
# Planning
###############################################################################

ENABLE_PLANNING=true
ENABLE_REASONING=true
ENABLE_MULTI_STEP_TASKS=true

###############################################################################
# Logging
###############################################################################

LOG_LEVEL=INFO

SAVE_AGENT_LOGS=true
SAVE_SCREENSHOTS=true
SAVE_BROWSER_VIDEO=false

###############################################################################
# Security
###############################################################################

API_SECRET=CHANGE_THIS_TO_A_LONG_RANDOM_SECRET

###############################################################################
# Cache
###############################################################################

CACHE_ENABLED=true
CACHE_DIR=./cache

###############################################################################
# Temporary Files
###############################################################################

TEMP_DIR=./tmp

###############################################################################
# Downloads
###############################################################################

DOWNLOAD_DIR=./downloads

###############################################################################
# Uploads
###############################################################################

UPLOAD_DIR=./uploads

###############################################################################
# Autonomous Agent
###############################################################################

ENABLE_BROWSER_AGENT=true
ENABLE_COMPUTER_CONTROL=true
ENABLE_SCREEN_ANALYSIS=true
ENABLE_OCR=true
ENABLE_SELF_HEALING=true
ENABLE_BACKGROUND_TASKS=true
ENABLE_TASK_MEMORY=true
ENABLE_LONG_TERM_MEMORY=true

###############################################################################
# Optional Integrations
###############################################################################

GITHUB_TOKEN=
SLACK_BOT_TOKEN=
DISCORD_BOT_TOKEN=
TELEGRAM_BOT_TOKEN=
NOTION_API_KEY=